<div class="search-form">
  <form method="POST" action="">
    <div class="mb-3 mt-4 form-group">
      <label for="search-input" class="form-label">Nhập từ khóa</label>
      <input
        name="q"
        type="text"
        class="form-control"
        id="search-input"
        placeholder="Nhập vào đây"
      />
    </div>

    <div class="mb-3 mt-4 form-group">
      <label for="gender-input" class="form-label">Giới tính</label>
      <select name="gender" type="text" class="form-control" id="gender-input">
        <option value="">-- Chọn giới tính --</option>
        <option value="male">Nam</option>
        <option value="female">Nữ</option>
      </select>

    </div>
    <button type="submit" class="btn btn-primary">Tìm kiếm</button>
  </form>
</div>